generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// An account that owns habits. `email` is the login identifier (stored
/// lowercase); `passwordHash` is a bcrypt hash — never the plain password.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  habits       Habit[]
  tags         Tag[]
}

/// A user-scoped label attached to any number of habits (implicit m2m).
/// `name` is stored normalized — trimmed, single-spaced, lowercase
/// (lib/tags.ts) — and is unique per user, never shared across users.
model Tag {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  habits Habit[]

  @@unique([userId, name])
}

/// A habit the user wants to build. `name` must be 1-50 chars and
/// `description` at most 200 chars (`color` is a hex string) — length rules
/// are enforced in the validation layer, since SQLite has no length-limited
/// string types. Every habit belongs to exactly one user; all queries must
/// filter by `userId`. `targetDays` is a 7-char 0/1 mask (index 0 = Sunday …
/// 6 = Saturday, ≥1 target day — validated in lib/target-days.ts); the
/// default means "every day".
model Habit {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String
  targetDays  String    @default("1111111")
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?
  checkIns    CheckIn[]
  tags        Tag[]

  @@index([userId])
}

/// One completed day for a habit. `date` is a YYYY-MM-DD string; a habit can
/// be checked in at most once per day.
model CheckIn {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}
